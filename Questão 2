public class Animal {
    private String nome;
    private String raca;
    public Animal(String nome, String raca){
        this.nome = nome;
        this.raca = raca;
    }
    public String nome(){
        return nome;
    }
    public void setNome(String nome){
        this.nome = nome;
    }
    public String raca(){
        return raca;
    }
    public void SetRaca(String raca){
        this.raca = raca;
    }
    public void caminha(){
        System.out.println("O animal caminha 20 metros");
    }
    public class cachorro extends Animal{
        
        public cachorro(String nome, String raca) {
            super(nome, raca);    
        }
        public void late(){
            System.out.println("Au Au.");
        }
    }
    public class gato extends Animal{
        
        public gato(String nome, String raca) {
            super(nome, raca);
        }
        public void mia(){
            System.out.println("Miau.");
        }
    }
}
